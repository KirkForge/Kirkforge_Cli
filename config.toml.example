# KirkForge example configuration
#
# Copy this file to ~/.local/share/kirkforge/config.toml and uncomment the
# settings you want to change. Any field omitted from the real config file
# keeps its built-in default, so a minimal config can be a single line.

# ---------------------------------------------------------------------------
# Model and endpoint
# ---------------------------------------------------------------------------

# Default model used when `kirkforge run` is invoked without `--model`.
# Examples: "kimi-2.7k-coder:cloud", "glm-5.2:cloud", "qwen3:32b:cloud",
# or any model name your Ollama / OpenAI-compatible gateway knows.
# Default: "" (empty — you must pick a model with -m/--model).
# default_model = ""

# URL of the Ollama or OpenAI-compatible gateway. This is where requests are
# routed; it can be a local Ollama install or a cloud provider endpoint.
# Default: "" (empty).
# ollama_host = ""

# ---------------------------------------------------------------------------
# Safety / approval
# ---------------------------------------------------------------------------

# When true, all tool calls and `!` passthrough are approved automatically.
# Useful for scripted non-interactive runs, dangerous for normal interactive
# coding. Default: false.
# auto_approve = false

# When true, destructive tools (write_file, edit_file, bash) report what they
# would do without actually doing it. Read-only tools still run normally.
# Useful for reviewing the model's intended edits before allowing them.
# Default: false.
# dry_run = false

# When true, the `!command` passthrough routes through the same approval gate
# as the bash tool. Default: false (passthrough is friction-free).
# bang_requires_approval = false

# ---------------------------------------------------------------------------
# Sandbox and filesystem access
# ---------------------------------------------------------------------------

# Working directory the bash tool defaults to and is confined inside. When
# omitted, the launch-time current working directory is used (sandboxed).
# An explicit path overrides cwd capture. An empty string ("") is the
# explicit opt-out that disables the sandbox. Default: omitted (cwd).
# sandbox_dir = "."

# When true, the bash tool forces its subprocess cwd inside `sandbox_dir` and
# rejects explicit `workdir` args that escape it. Default: true.
# bash_sandbox_workdir = true

# When true, write_file/edit_file reject paths that resolve inside dotfile
# directories (e.g. ~/.ssh). Default: false.
# block_dotfiles = false

# When true, write_file/edit_file also reject paths inside git-ignored dotfile
# directories such as .env files. Default: true.
# block_gitignored_dotfiles = true

# When true, read_file rejects binary files instead of returning truncated
# base64. Default: false.
# block_binary_reads = false

# Maximum bytes the read_file tool returns. Default: 1048576 (1 MiB).
# max_file_read_size = 1048576

# Maximum size (in bytes) of an existing file that write_file/edit_file may
# overwrite. Set to 0 to disable the limit. Default: 1048576 (1 MiB).
# max_overwrite_size = 1048576

# When true, read_file follows symlinks. Default: false.
# follow_symlinks = false

# ---------------------------------------------------------------------------
# Deny / allow lists
# ---------------------------------------------------------------------------

# Glob patterns for paths the file tools are not allowed to touch.
# deny_paths = ["**/.ssh/**", "**/secret/**"]

# Glob patterns for URLs the bash tool is not allowed to curl/wget/etc.
# deny_urls = ["https://example.com/internal/*"]

# File extensions that file tools will refuse to write.
# deny_extensions = [".key", "*.pem"]

# If non-empty, write_file/edit_file outside these directories are rejected.
# allowed_write_dirs = ["/home/me/projects"]

# ---------------------------------------------------------------------------
# Conversation context
# ---------------------------------------------------------------------------

# How the context window is shrunk when it grows too long.
# Options: "KeepToolOnly" (default), "DropOldest", "SummarizeMiddle".
# truncation_strategy = "KeepToolOnly"

# When true, old turns are carried over into new sessions. Default: true.
# carryover_enabled = true

# Maximum characters of a single tool result that are kept in context.
# Default: 4000.
# max_tool_result_chars = 4000

# Number of recent messages kept verbatim during context compaction. Must be
# at least 1. Default: 2 (one user turn + one assistant turn).
# preserve_recent_messages = 2

# Maximum model↔tool iterations within a single turn. Prevents runaway loops
# during large codebase analysis. Default: 50.
# max_tool_calls_per_turn = 50

# ---------------------------------------------------------------------------
# Summarization (optional LLM-based compaction)
# ---------------------------------------------------------------------------

# When true, `/compact` uses the model below to summarize old turns instead
# of naive truncation. Falls back to truncation if summarization fails.
# summarize_enabled = false

# Fast/cheap model used for summarization. Empty means summarization is
# disabled by default.
# summarize_model = ""

# ---------------------------------------------------------------------------
# Smart routing (experimental)
# ---------------------------------------------------------------------------

# When true, the first user message each turn is classified by complexity and
# the router may suggest a model tier. Advisory only today.
# routing_enabled = false

# Model used for complexity classification. Empty means keyword heuristics.
# router_model = ""

# Per-tier model overrides. Valid keys: "simple", "medium", "complex".
# [routing_model_map]
# simple = "qwen3:32b:cloud"
# medium = "glm-5.2:cloud"
# complex = "kimi-2.7k-coder:cloud"

# ---------------------------------------------------------------------------
# MCP servers (optional external tools)
# ---------------------------------------------------------------------------
#
# Each server is spawned as a subprocess. Its tools become available inside
# KirkForge prefixed with `mcp/<name>/`.

# [[mcp_servers]]
# name = "fetch"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-fetch"]
# [mcp_servers.env_vars]
# LOG_LEVEL = "warn"

# ---------------------------------------------------------------------------
# Output / model behavior
# ---------------------------------------------------------------------------

# When true, request JSON-formatted responses. Models vary in how well they
# honor this; tool calls may still appear inline. Default: false.
# json_mode = false

# ---------------------------------------------------------------------------
# Git commit helper
# ---------------------------------------------------------------------------

# Maximum file size (in bytes) allowed in a `/commit`. Files larger than this
# are a hard blocker. Default: 5242880 (5 MiB).
# commit_max_file_size = 5242880

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Per-tool hard timeout in seconds. Individual tools may apply shorter
# internal timeouts. Clamped to [1, 3600]. Default: 30.
# tool_timeout_secs = 30

# Optional path for the append-only JSONL audit log. Set to an empty string
# to disable auditing. Default: <data_dir>/audit.ndjson.
# audit_log_path = ""

# Optional directory containing lifecycle hook scripts (`<event>.sh`). When
# omitted, the default `~/.local/share/kirkforge/hooks/` is used.
# hooks_dir = ""

# ---------------------------------------------------------------------------
# Workspace plugin sources
# ---------------------------------------------------------------------------
#
# The CLI ships with five built-in plugin sources under the `plugins/` directory.
# They are enabled by default (in the order below) when the directories exist.
# Disable individual plugins at runtime with `/plugins toggle <name>` or remove
# them from `enabled_plugins`. Relative paths resolve against the current working
# directory; in an installed release the bundled plugins are looked up under
# `~/.local/share/kirkforge/plugins/<name>`.
#
# [plugin_sources]
# kirkforge-draw = "plugins/kirkforge-draw"
# kirkforge-video = "plugins/kirkforge-video"
# stratum = "plugins/stratum"
# kirkforge-plugin3 = "plugins/kirkforge-plugin3"
# kirkforge-plugin = "plugins/kirkforge-plugin"
#
enabled_plugins = ["kirkforge-draw", "kirkforge-video", "stratum", "kirkforge-plugin3", "kirkforge-plugin"]
