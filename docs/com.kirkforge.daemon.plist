<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kirkforge.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/USER/.local/bin/kirkforge</string>
        <string>daemon</string>
        <string>--foreground</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/USER/.local/share/kirkforge/logs/daemon.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/USER/.local/share/kirkforge/logs/daemon.log</string>
</dict>
</plist>
