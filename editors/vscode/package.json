{
  "name": "kirkforge-vscode",
  "displayName": "KirkForge",
  "description": "Open-source coding agent extension for VS Code — launches KirkForge in the integrated terminal",
  "version": "0.1.0",
  "publisher": "kirkforge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KirkForge/KirkForge-Cli.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "coding agent",
    "ollama",
    "cli",
    "tui"
  ],
  "activationEvents": [
    "onCommand:kirkforge.start"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kirkforge.start",
        "title": "Start KirkForge",
        "category": "KirkForge"
      }
    ],
    "configuration": {
      "title": "KirkForge",
      "properties": {
        "kirkforge.binaryPath": {
          "type": "string",
          "default": "kirkforge",
          "description": "Path to the kirkforge binary (name on PATH or absolute path)."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "npm run build && node --test 'out/test/**/*.test.js'",
    "package:vsce": "node node_modules/@vscode/vsce/vsce package",
    "publish:ovsx": "node node_modules/ovsx/bin/ovsx publish kirkforge-vscode-0.1.0.vsix"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "^3.9.2",
    "ovsx": "^0.10.12",
    "typescript": "^5.9.3"
  }
}
