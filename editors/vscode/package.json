{
  "name": "kirkforge-vscode",
  "displayName": "KirkForge",
  "description": "AI coding agent extension for VS Code — chat panel, inline diffs, TODO panel, and LSP bridge",
  "version": "0.2.0",
  "publisher": "kirkforge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KirkForge/KirkForge-Cli.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "coding agent",
    "ollama",
    "cli",
    "tui"
  ],
  "activationEvents": [
    "onCommand:kirkforge.startPanel",
    "onCommand:kirkforge.startTerminal"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kirkforge.startPanel",
        "title": "Start KirkForge Panel",
        "category": "KirkForge"
      },
      {
        "command": "kirkforge.startTerminal",
        "title": "Start KirkForge Terminal",
        "category": "KirkForge"
      },
      {
        "command": "kirkforge.acceptEdit",
        "title": "Accept KirkForge Edit",
        "category": "KirkForge"
      },
      {
        "command": "kirkforge.rejectEdit",
        "title": "Reject KirkForge Edit",
        "category": "KirkForge"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "kirkforge.todo",
          "name": "KirkForge TODO",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "KirkForge",
      "properties": {
        "kirkforge.binaryPath": {
          "type": "string",
          "default": "kirkforge",
          "description": "Path to the kirkforge binary (name on PATH or absolute path)."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "npm run build && node --test 'out/test/**/*.test.js'",
    "package:vsce": "node node_modules/@vscode/vsce/vsce package --no-yarn"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.9.3"
  }
}