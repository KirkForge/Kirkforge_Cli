{
  "name": "kirkforge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Deterministic delegation plugin for coding agents — verification, correction, and routing layer that plugs into Codex, Claude Code, OpenCode, and LangChain-style systems",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "npm run build && bash scripts/test-batched.sh",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage.enabled=true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages apps",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf packages/*/dist apps/*/dist packages/*/tsconfig.tsbuildinfo apps/*/tsconfig.tsbuildinfo",
    "test:adapter": "bash examples/shell-adapter/test-adapter.sh",
    "ci": "bash scripts/ci.sh",
    "cli": "npx tsx apps/cli/src/index.ts",
    "test:ci": "bash scripts/test-batched.sh",
    "test:e2e": "vitest run e2e/",
    "test:all": "bash scripts/test-batched.sh && vitest run e2e/",
    "docs:api": "typedoc",
    "self-verify": "npx tsx apps/cli/src/index.ts verify --task \"verify self\""
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "pyright": "^1.1.411",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0"
}
